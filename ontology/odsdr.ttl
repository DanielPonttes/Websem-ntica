@prefix odsdr: <http://www.semanticweb.org/daniel-pontes/ontologies/2025/9/respiratory-diseases-ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.semanticweb.org/daniel-pontes/ontologies/2025/9/respiratory-diseases-ontology/> a owl:Ontology ;
    owl:versionInfo "2.0.0" ;
    rdfs:label "ODSDR"@pt-BR ;
    rdfs:comment "Ontologia ODSDR em OWL 2 DL — 10 doencas respiratorias, 17 sintomas. Fontes: OMS ICD-11, Harrison 21ed, GOLD 2024, GINA 2024."@pt-BR .

# ============================================================
# CLASSES (TBox)
# ============================================================

odsdr:Doenca a owl:Class ;
    rdfs:label "Doenca"@pt-BR ;
    rdfs:comment "Entidade nosologica do dominio respiratorio."@pt-BR .

odsdr:Sintoma a owl:Class ;
    rdfs:label "Sintoma"@pt-BR ;
    rdfs:comment "Manifestacao clinica observavel no paciente."@pt-BR .

odsdr:Diagnostico a owl:Class ;
    rdfs:label "Diagnostico"@pt-BR ;
    rdfs:comment "Conclusao clinica sobre uma doenca com base em evidencias."@pt-BR .

odsdr:Exame a owl:Class ;
    rdfs:label "Exame"@pt-BR ;
    rdfs:comment "Procedimento de avaliacao clinica complementar."@pt-BR .

odsdr:Tratamento a owl:Class ;
    rdfs:label "Tratamento"@pt-BR ;
    rdfs:comment "Intervencao terapeutica para reduzir sintomas ou tratar doenca."@pt-BR .

odsdr:Medicamento a owl:Class ;
    rdfs:subClassOf odsdr:Tratamento ;
    rdfs:label "Medicamento"@pt-BR ;
    rdfs:comment "Subtipo de tratamento baseado em farmaco."@pt-BR .

odsdr:FatorRisco a owl:Class ;
    rdfs:label "Fator de risco"@pt-BR ;
    rdfs:comment "Condicao que aumenta a probabilidade de doenca."@pt-BR .

odsdr:Anatomia a owl:Class ;
    rdfs:label "Anatomia"@pt-BR ;
    rdfs:comment "Estrutura anatomica relacionada ao sistema respiratorio."@pt-BR .

odsdr:Paciente a owl:Class ;
    rdfs:label "Paciente"@pt-BR ;
    rdfs:comment "Pessoa atendida no contexto clinico."@pt-BR .

odsdr:ProfissionalSaude a owl:Class ;
    rdfs:label "Profissional de saude"@pt-BR ;
    rdfs:comment "Profissional responsavel por analise, diagnostico e conduta."@pt-BR .

odsdr:Causa a owl:Class ;
    rdfs:label "Causa"@pt-BR ;
    rdfs:comment "Fator etiologico associado a uma doenca."@pt-BR .

# ============================================================
# CLASSES DEFINIDAS — Caso Provavel (inferencia OWL)
# ============================================================

odsdr:CasoProvavelPneumonia a owl:Class ;
    rdfs:label "Caso provavel de pneumonia"@pt-BR ;
    rdfs:comment "Paciente com tosse, febre e raio X de torax."@pt-BR ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            odsdr:Paciente
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:Tosse ]
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:Febre ]
            [ a owl:Restriction ; owl:onProperty odsdr:realiza ; owl:hasValue odsdr:RaioXTorax ]
        )
    ] .

odsdr:CasoProvavelAsma a owl:Class ;
    rdfs:label "Caso provavel de asma"@pt-BR ;
    rdfs:comment "Paciente com falta de ar, chiado no peito e espirometria."@pt-BR ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            odsdr:Paciente
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:FaltaDeAr ]
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:ChiadoNoPeito ]
            [ a owl:Restriction ; owl:onProperty odsdr:realiza ; owl:hasValue odsdr:Espirometria ]
        )
    ] .

odsdr:CasoProvavelBronquite a owl:Class ;
    rdfs:label "Caso provavel de bronquite"@pt-BR ;
    rdfs:comment "Paciente com tosse, chiado no peito e espirometria."@pt-BR ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            odsdr:Paciente
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:Tosse ]
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:ChiadoNoPeito ]
            [ a owl:Restriction ; owl:onProperty odsdr:realiza ; owl:hasValue odsdr:Espirometria ]
        )
    ] .

odsdr:CasoProvavelCOVID19 a owl:Class ;
    rdfs:label "Caso provavel de COVID-19"@pt-BR ;
    rdfs:comment "Paciente com tosse, febre e exame PCR."@pt-BR ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            odsdr:Paciente
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:Tosse ]
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:Febre ]
            [ a owl:Restriction ; owl:onProperty odsdr:realiza ; owl:hasValue odsdr:PCR ]
        )
    ] .

odsdr:CasoProvavelTuberculose a owl:Class ;
    rdfs:label "Caso provavel de tuberculose"@pt-BR ;
    rdfs:comment "Paciente com tosse, sudorese noturna e baciloscopia BK. Fonte: OMS/ICD-11 1B10."@pt-BR ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            odsdr:Paciente
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:Tosse ]
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:SudoreseNoturna ]
            [ a owl:Restriction ; owl:onProperty odsdr:realiza ; owl:hasValue odsdr:BaciloscopiaBK ]
        )
    ] .

odsdr:CasoProvavelDPOC a owl:Class ;
    rdfs:label "Caso provavel de DPOC"@pt-BR ;
    rdfs:comment "Paciente com tosse, falta de ar e expectoracao cronica. Fonte: GOLD 2024."@pt-BR ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            odsdr:Paciente
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:Tosse ]
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:FaltaDeAr ]
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:ExpectoracaoCronica ]
            [ a owl:Restriction ; owl:onProperty odsdr:realiza ; owl:hasValue odsdr:Espirometria ]
        )
    ] .

odsdr:CasoProvavelGripe a owl:Class ;
    rdfs:label "Caso provavel de gripe"@pt-BR ;
    rdfs:comment "Paciente com febre, tosse, dor no corpo e teste rapido. Fonte: OMS/ICD-11 1E30."@pt-BR ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            odsdr:Paciente
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:Febre ]
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:Tosse ]
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:DorNoCorpo ]
            [ a owl:Restriction ; owl:onProperty odsdr:realiza ; owl:hasValue odsdr:TesteRapidoInfluenza ]
        )
    ] .

odsdr:CasoProvavelSinusite a owl:Class ;
    rdfs:label "Caso provavel de sinusite"@pt-BR ;
    rdfs:comment "Paciente com dor facial, congestao nasal e tomografia. Fonte: Harrison 21ed."@pt-BR ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            odsdr:Paciente
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:DorFacial ]
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:CongestaoNasal ]
            [ a owl:Restriction ; owl:onProperty odsdr:realiza ; owl:hasValue odsdr:TomografiaDosSeios ]
        )
    ] .

odsdr:CasoProvavelEmboliaPulmonar a owl:Class ;
    rdfs:label "Caso provavel de embolia pulmonar"@pt-BR ;
    rdfs:comment "Paciente com falta de ar, dor toracica e taquicardia. Fonte: Harrison 21ed."@pt-BR ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            odsdr:Paciente
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:FaltaDeAr ]
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:DorToracica ]
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:Taquicardia ]
            [ a owl:Restriction ; owl:onProperty odsdr:realiza ; owl:hasValue odsdr:AngiotomografiaPulmonar ]
        )
    ] .

odsdr:CasoProvavelLaringite a owl:Class ;
    rdfs:label "Caso provavel de laringite"@pt-BR ;
    rdfs:comment "Paciente com rouquidao, dor de garganta e laringoscopia. Fonte: OMS/ICD-11 CA04."@pt-BR ;
    owl:equivalentClass [
        a owl:Class ;
        owl:intersectionOf (
            odsdr:Paciente
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:Rouquidao ]
            [ a owl:Restriction ; owl:onProperty odsdr:apresenta ; owl:hasValue odsdr:DorDeGarganta ]
            [ a owl:Restriction ; owl:onProperty odsdr:realiza ; owl:hasValue odsdr:LaringoscopiaIndireta ]
        )
    ] .

# ============================================================
# DISJOINTNESS
# ============================================================

[] a owl:AllDisjointClasses ;
    owl:members (
        odsdr:Doenca
        odsdr:Sintoma
        odsdr:Diagnostico
        odsdr:Exame
        odsdr:Tratamento
        odsdr:FatorRisco
        odsdr:Anatomia
        odsdr:Paciente
        odsdr:ProfissionalSaude
        odsdr:Causa
    ) .

# ============================================================
# OBJECT PROPERTIES
# ============================================================

odsdr:provoca a owl:ObjectProperty ;
    rdfs:label "provoca"@pt-BR ;
    rdfs:comment "Relaciona uma doenca aos sintomas que ela provoca."@pt-BR ;
    rdfs:domain odsdr:Doenca ;
    rdfs:range odsdr:Sintoma ;
    owl:inverseOf odsdr:eSintomaDe .

odsdr:eSintomaDe a owl:ObjectProperty ;
    rdfs:label "e sintoma de"@pt-BR ;
    rdfs:domain odsdr:Sintoma ;
    rdfs:range odsdr:Doenca .

odsdr:possuiCausa a owl:ObjectProperty ;
    rdfs:label "possui causa"@pt-BR ;
    rdfs:domain odsdr:Doenca ;
    rdfs:range odsdr:Causa .

odsdr:aflige a owl:ObjectProperty ;
    rdfs:label "aflige"@pt-BR ;
    rdfs:domain odsdr:Doenca ;
    rdfs:range odsdr:Paciente .

odsdr:diagnosticadaPor a owl:ObjectProperty ;
    rdfs:label "diagnosticada por"@pt-BR ;
    rdfs:domain odsdr:Doenca ;
    rdfs:range odsdr:ProfissionalSaude .

odsdr:doencaRecebeTratamento a owl:ObjectProperty ;
    rdfs:label "doenca recebe tratamento"@pt-BR ;
    rdfs:domain odsdr:Doenca ;
    rdfs:range odsdr:Tratamento .

odsdr:detectadaPor a owl:ObjectProperty ;
    rdfs:label "detectada por"@pt-BR ;
    rdfs:domain odsdr:Doenca ;
    rdfs:range odsdr:Exame ;
    owl:inverseOf odsdr:detectaDoenca .

odsdr:detectaDoenca a owl:ObjectProperty ;
    rdfs:label "detecta doenca"@pt-BR ;
    rdfs:domain odsdr:Exame ;
    rdfs:range odsdr:Doenca .

odsdr:ataca a owl:ObjectProperty ;
    rdfs:label "ataca"@pt-BR ;
    rdfs:domain odsdr:Doenca ;
    rdfs:range odsdr:Anatomia .

odsdr:facilitadaPor a owl:ObjectProperty ;
    rdfs:label "facilitada por"@pt-BR ;
    rdfs:domain odsdr:Doenca ;
    rdfs:range odsdr:FatorRisco .

odsdr:apresenta a owl:ObjectProperty ;
    rdfs:label "apresenta"@pt-BR ;
    rdfs:domain odsdr:Paciente ;
    rdfs:range odsdr:Sintoma .

odsdr:atendidoPor a owl:ObjectProperty ;
    rdfs:label "atendido por"@pt-BR ;
    rdfs:domain odsdr:Paciente ;
    rdfs:range odsdr:ProfissionalSaude .

odsdr:recebeDiagnostico a owl:ObjectProperty ;
    rdfs:label "recebe diagnostico"@pt-BR ;
    rdfs:domain odsdr:Paciente ;
    rdfs:range odsdr:Diagnostico .

odsdr:realiza a owl:ObjectProperty ;
    rdfs:label "realiza"@pt-BR ;
    rdfs:domain odsdr:Paciente ;
    rdfs:range odsdr:Exame .

odsdr:possuiFatorRisco a owl:ObjectProperty ;
    rdfs:label "possui fator de risco"@pt-BR ;
    rdfs:domain odsdr:Paciente ;
    rdfs:range odsdr:FatorRisco .

odsdr:pacienteRecebeTratamento a owl:ObjectProperty ;
    rdfs:label "paciente recebe tratamento"@pt-BR ;
    rdfs:domain odsdr:Paciente ;
    rdfs:range odsdr:Tratamento .

odsdr:diagnosticaDoenca a owl:ObjectProperty ;
    rdfs:label "diagnostica doenca"@pt-BR ;
    rdfs:domain odsdr:Diagnostico ;
    rdfs:range odsdr:Doenca .

odsdr:geradoApartirDe a owl:ObjectProperty ;
    rdfs:label "gerado a partir de"@pt-BR ;
    rdfs:domain odsdr:Diagnostico ;
    rdfs:range odsdr:Exame .

odsdr:geraTratamento a owl:ObjectProperty ;
    rdfs:label "gera tratamento"@pt-BR ;
    rdfs:domain odsdr:Diagnostico ;
    rdfs:range odsdr:Tratamento .

odsdr:aliviadoPor a owl:ObjectProperty ;
    rdfs:label "aliviado por"@pt-BR ;
    rdfs:domain odsdr:Sintoma ;
    rdfs:range odsdr:Tratamento .

odsdr:examina a owl:ObjectProperty ;
    rdfs:label "examina"@pt-BR ;
    rdfs:domain odsdr:Exame ;
    rdfs:range odsdr:Anatomia .

odsdr:predispoe a owl:ObjectProperty ;
    rdfs:label "predispoe"@pt-BR ;
    rdfs:domain odsdr:Causa ;
    rdfs:range odsdr:FatorRisco .

odsdr:aumentaRiscoPara a owl:ObjectProperty ;
    rdfs:label "aumenta risco para"@pt-BR ;
    rdfs:domain odsdr:FatorRisco ;
    rdfs:range odsdr:Doenca .

# ============================================================
# DATATYPE PROPERTIES
# ============================================================

odsdr:idade a owl:DatatypeProperty ;
    rdfs:domain odsdr:Paciente ;
    rdfs:range xsd:integer .

odsdr:sexo a owl:DatatypeProperty ;
    rdfs:domain odsdr:Paciente ;
    rdfs:range xsd:string .

odsdr:fumante a owl:DatatypeProperty ;
    rdfs:domain odsdr:Paciente ;
    rdfs:range xsd:boolean .

odsdr:dataDiagnostico a owl:DatatypeProperty ;
    rdfs:domain odsdr:Diagnostico ;
    rdfs:range xsd:date .

odsdr:resultadoTexto a owl:DatatypeProperty ;
    rdfs:domain odsdr:Exame ;
    rdfs:range xsd:string .

odsdr:resultadoPositivo a owl:DatatypeProperty ;
    rdfs:domain odsdr:Exame ;
    rdfs:range xsd:boolean .

# ============================================================
# DOENCAS (10) — Fontes: OMS ICD-11, Harrison 21ed, GOLD 2024
# ============================================================

odsdr:Asma a owl:NamedIndividual, odsdr:Doenca ;
    rdfs:comment "ICD-11 CA23. Fonte: GINA 2024."@pt-BR .
odsdr:Bronquite a owl:NamedIndividual, odsdr:Doenca ;
    rdfs:comment "ICD-11 CA20. Fonte: Harrison 21ed."@pt-BR .
odsdr:Pneumonia a owl:NamedIndividual, odsdr:Doenca ;
    rdfs:comment "ICD-11 CA40. Fonte: Harrison 21ed."@pt-BR .
odsdr:COVID19 a owl:NamedIndividual, odsdr:Doenca ;
    rdfs:comment "ICD-11 RA01.0. Fonte: OMS 2024."@pt-BR .
odsdr:Tuberculose a owl:NamedIndividual, odsdr:Doenca ;
    rdfs:comment "ICD-11 1B10. Fonte: OMS Global TB Report 2024."@pt-BR .
odsdr:DPOC a owl:NamedIndividual, odsdr:Doenca ;
    rdfs:comment "ICD-11 CA22. Fonte: GOLD 2024."@pt-BR .
odsdr:Gripe a owl:NamedIndividual, odsdr:Doenca ;
    rdfs:comment "ICD-11 1E30. Fonte: OMS."@pt-BR .
odsdr:Sinusite a owl:NamedIndividual, odsdr:Doenca ;
    rdfs:comment "ICD-11 CA0A. Fonte: Harrison 21ed."@pt-BR .
odsdr:EmboliaPulmonar a owl:NamedIndividual, odsdr:Doenca ;
    rdfs:comment "ICD-11 BB00. Fonte: Harrison 21ed."@pt-BR .
odsdr:Laringite a owl:NamedIndividual, odsdr:Doenca ;
    rdfs:comment "ICD-11 CA04. Fonte: Harrison 21ed."@pt-BR .

# ============================================================
# SINTOMAS (17)
# ============================================================

odsdr:Tosse a owl:NamedIndividual, odsdr:Sintoma .
odsdr:Febre a owl:NamedIndividual, odsdr:Sintoma .
odsdr:FaltaDeAr a owl:NamedIndividual, odsdr:Sintoma .
odsdr:ChiadoNoPeito a owl:NamedIndividual, odsdr:Sintoma .
odsdr:SudoreseNoturna a owl:NamedIndividual, odsdr:Sintoma .
odsdr:PerdaDePeso a owl:NamedIndividual, odsdr:Sintoma .
odsdr:Hemoptise a owl:NamedIndividual, odsdr:Sintoma ;
    rdfs:comment "Expectoracao com sangue."@pt-BR .
odsdr:ExpectoracaoCronica a owl:NamedIndividual, odsdr:Sintoma ;
    rdfs:comment "Producao persistente de secrecao bronquica."@pt-BR .
odsdr:DorDeCabeca a owl:NamedIndividual, odsdr:Sintoma .
odsdr:DorNoCorpo a owl:NamedIndividual, odsdr:Sintoma ;
    rdfs:comment "Mialgia generalizada."@pt-BR .
odsdr:Calafrios a owl:NamedIndividual, odsdr:Sintoma .
odsdr:DorFacial a owl:NamedIndividual, odsdr:Sintoma ;
    rdfs:comment "Dor na regiao dos seios paranasais."@pt-BR .
odsdr:CongestaoNasal a owl:NamedIndividual, odsdr:Sintoma .
odsdr:DorToracica a owl:NamedIndividual, odsdr:Sintoma ;
    rdfs:comment "Dor toracica, pode ser pleuritica."@pt-BR .
odsdr:Taquicardia a owl:NamedIndividual, odsdr:Sintoma ;
    rdfs:comment "FC > 100 bpm."@pt-BR .
odsdr:Rouquidao a owl:NamedIndividual, odsdr:Sintoma ;
    rdfs:comment "Disfonia."@pt-BR .
odsdr:DorDeGarganta a owl:NamedIndividual, odsdr:Sintoma .

# ============================================================
# EXAMES (9)
# ============================================================

odsdr:RaioXTorax a owl:NamedIndividual, odsdr:Exame ;
    odsdr:examina odsdr:Pulmoes .
odsdr:PCR a owl:NamedIndividual, odsdr:Exame ;
    odsdr:examina odsdr:Pulmoes .
odsdr:Espirometria a owl:NamedIndividual, odsdr:Exame ;
    odsdr:examina odsdr:Bronquios .
odsdr:BaciloscopiaBK a owl:NamedIndividual, odsdr:Exame ;
    rdfs:comment "Pesquisa de BAAR no escarro. Fonte: OMS."@pt-BR ;
    odsdr:examina odsdr:Pulmoes .
odsdr:TesteRapidoInfluenza a owl:NamedIndividual, odsdr:Exame ;
    rdfs:comment "Teste de antigeno para Influenza A/B."@pt-BR ;
    odsdr:examina odsdr:Pulmoes .
odsdr:TomografiaDosSeios a owl:NamedIndividual, odsdr:Exame ;
    rdfs:comment "TC dos seios paranasais."@pt-BR ;
    odsdr:examina odsdr:SeiosParanasais .
odsdr:AngiotomografiaPulmonar a owl:NamedIndividual, odsdr:Exame ;
    rdfs:comment "Angiotomografia para TEP."@pt-BR ;
    odsdr:examina odsdr:Pulmoes .
odsdr:LaringoscopiaIndireta a owl:NamedIndividual, odsdr:Exame ;
    rdfs:comment "Espelho laringeo."@pt-BR ;
    odsdr:examina odsdr:Laringe .
odsdr:Hemograma a owl:NamedIndividual, odsdr:Exame ;
    rdfs:comment "Hemograma completo."@pt-BR .

# ============================================================
# TRATAMENTOS (7)
# ============================================================

odsdr:Antibiotico a owl:NamedIndividual, odsdr:Tratamento .
odsdr:Broncodilatador a owl:NamedIndividual, odsdr:Medicamento .
odsdr:Hidratacao a owl:NamedIndividual, odsdr:Tratamento .
odsdr:Rifampicina a owl:NamedIndividual, odsdr:Medicamento ;
    rdfs:comment "1a linha para TB. Fonte: OMS."@pt-BR .
odsdr:Oseltamivir a owl:NamedIndividual, odsdr:Medicamento ;
    rdfs:comment "Antiviral para Influenza."@pt-BR .
odsdr:Anticoagulante a owl:NamedIndividual, odsdr:Medicamento ;
    rdfs:comment "Heparina/Enoxaparina para TEP."@pt-BR .
odsdr:AntiInflamatorio a owl:NamedIndividual, odsdr:Medicamento ;
    rdfs:comment "Anti-inflamatorio para laringite."@pt-BR .

# ============================================================
# FATORES DE RISCO (5)
# ============================================================

odsdr:Tabagismo a owl:NamedIndividual, odsdr:FatorRisco .
odsdr:IdadeAvancada a owl:NamedIndividual, odsdr:FatorRisco .
odsdr:ComorbidadePulmonar a owl:NamedIndividual, odsdr:FatorRisco .
odsdr:Imunossupressao a owl:NamedIndividual, odsdr:FatorRisco ;
    rdfs:comment "Sistema imunologico comprometido."@pt-BR .
odsdr:PoluicaoDoAr a owl:NamedIndividual, odsdr:FatorRisco ;
    rdfs:comment "Exposicao a poluentes. Fonte: GOLD 2024."@pt-BR .

# ============================================================
# ANATOMIA (4) / CAUSAS (4) / PROFISSIONAIS
# ============================================================

odsdr:Pulmoes a owl:NamedIndividual, odsdr:Anatomia .
odsdr:Bronquios a owl:NamedIndividual, odsdr:Anatomia .
odsdr:SeiosParanasais a owl:NamedIndividual, odsdr:Anatomia .
odsdr:Laringe a owl:NamedIndividual, odsdr:Anatomia .

odsdr:InfeccaoBacteriana a owl:NamedIndividual, odsdr:Causa .
odsdr:InfeccaoViral a owl:NamedIndividual, odsdr:Causa .
odsdr:Alergeno a owl:NamedIndividual, odsdr:Causa .
odsdr:Tromboembolismo a owl:NamedIndividual, odsdr:Causa .

odsdr:MedicaAna a owl:NamedIndividual, odsdr:ProfissionalSaude .
odsdr:MedicoBruno a owl:NamedIndividual, odsdr:ProfissionalSaude .
odsdr:MedicaCarla a owl:NamedIndividual, odsdr:ProfissionalSaude .

# ============================================================
# RELACOES DOENCA → SINTOMAS / EXAMES / TRATAMENTOS
# ============================================================

odsdr:Pneumonia
    odsdr:provoca odsdr:Tosse, odsdr:Febre, odsdr:FaltaDeAr, odsdr:Calafrios, odsdr:DorToracica ;
    odsdr:detectadaPor odsdr:RaioXTorax, odsdr:Hemograma ;
    odsdr:ataca odsdr:Pulmoes ;
    odsdr:possuiCausa odsdr:InfeccaoBacteriana ;
    odsdr:facilitadaPor odsdr:Tabagismo, odsdr:IdadeAvancada, odsdr:Imunossupressao ;
    odsdr:doencaRecebeTratamento odsdr:Antibiotico .

odsdr:COVID19
