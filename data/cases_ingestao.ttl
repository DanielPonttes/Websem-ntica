odsdr:Bronquite odsdr:aflige odsdr:PacienteNovoPaciente111 .

odsdr:MedicaCarla odsdr:defineDiagnostico odsdr:DiagnosticoNovoPaciente111 .

odsdr:PacienteApi20260210055135 a odsdr:Paciente,
        owl:NamedIndividual ;
    odsdr:apresenta odsdr:Febre,
        odsdr:Tosse ;
    odsdr:atendidoPor odsdr:MedicaAna ;
    odsdr:fumante false ;
    odsdr:idade 38 ;
    odsdr:pacienteRecebeTratamento odsdr:Hidratacao ;
    odsdr:realiza odsdr:PCR ;
    odsdr:recebeDiagnostico odsdr:DiagnosticoApi20260210055135 ;
    odsdr:sexo "F" .

